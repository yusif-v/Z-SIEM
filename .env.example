# Z-SIEM Environment Config
# Copy to .env: cp .env.example .env

# PostgreSQL (shared - IRIS + N8N use separate DB names)
POSTGRES_MULTIPLE_DATABASES=iris,n8n

# DFIR-IRIS
IRIS_DB_PASSWORD=changemeiris2026
IRIS_REDIS_PASSWORD=changemeredis2026
IRIS_RABBITMQ_PASSWORD=changemerabbit2026
IRIS_SECRET_KEY=generate_openssl_rand_hex_64
IRIS_SECURITY_SALT=generaterandomstring32chars
# Initial admin password — login user is 'administrator'. Applied on first boot only.
# REQUIRED: compose will refuse to start if this is unset. Use a strong value.
IRIS_ADM_PASSWORD=changemeadmin2026
# IRIS hardcodes Secure session cookies (HTTPS-only). For internal HTTP-only
# access without a TLS proxy, set this to "false" — iris-web rewrites the flag
# at startup so login works over plain http://<ip>:8000. Leave "true" (default)
# in any deployment reachable over an untrusted network, and use HTTPS instead.
IRIS_COOKIE_SECURE=false

# N8N
N8N_DB_PASSWORD=changemen8n2026
IRIS_API_KEY=get_from_iris_ui

# General
TZ=UTC

# ─── v2 Enrichment (threat-intel providers) ───
# AbuseIPDB: https://www.abuseipdb.com/account/api  (free 1000 checks/day)
ABUSEIPDB_API_KEY=
# Shodan: https://account.shodan.io/  (free tier limited)
SHODAN_API_KEY=
# AlienVault OTX: https://otx.alienvault.com/api  (free, no hard limit)
OTX_API_KEY=
# Cache TTLs (seconds): IP reputation 24h, Shodan host 24h, OTX 24h, hashes 7d
ENRICH_TTL_IP=86400
ENRICH_TTL_SHODAN=86400
ENRICH_TTL_OTX=86400
ENRICH_TTL_HASH=604800
