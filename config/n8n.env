# N8N Environment Variables for Z-SIEM
# These are read by the workflow via $env.<NAME>
# Copy into your .env or set in docker-compose environment

# DFIR-IRIS API Configuration
IRIS_API_URL=http://iris-web:8000
IRIS_API_KEY=<YOUR_IRIS_API_KEY_HERE>

# How to get the IRIS API key:
# 1. Start the stack: docker compose up -d
# 2. Wait for IRIS to be ready (~90 seconds)
# 3. Open http://localhost:8000 and login (admin / admin initial setup)
# 4. Go to Users -> Your User -> API Key
# 5. Copy the key and paste above

# Webhook callback base (from N8N perspective)
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http

# SLA severity mapping (used in workflow):
# SLA ID 1 = normal (low severity) — 24h
# SLA ID 2 = elevated (medium/high) — 8h
# SLA ID 3 = critical — 4h
